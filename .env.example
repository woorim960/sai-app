# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Data source: mock (default) | supabase
NEXT_PUBLIC_DATA_SOURCE=mock

# Group store: memory (local dev) | supabase (production — Vercel 등 서버리스 필수)
NEXT_PUBLIC_GROUP_STORE=memory

# Couple store: memory (default) | supabase
NEXT_PUBLIC_COUPLE_STORE=memory

# Supabase (required when store/data source = supabase)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 그룹 세션 HMAC (production에서 반드시 랜덤 값으로 설정)
GROUP_SESSION_SECRET=change-me-in-production
