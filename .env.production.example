# Vercel Production — Environment Variables 탭에 아래 값을 등록하세요.
# 절대 git에 커밋하지 마세요.

NEXT_PUBLIC_SITE_URL=https://YOUR_PROJECT.vercel.app

NEXT_PUBLIC_DATA_SOURCE=supabase
NEXT_PUBLIC_GROUP_STORE=supabase
NEXT_PUBLIC_COUPLE_STORE=memory

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

GROUP_SESSION_SECRET=run-npm-run-generate-secret
GROUP_TTL_DAYS=7
